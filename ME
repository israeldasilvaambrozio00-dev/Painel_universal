local function NewToggle(parent, txt, optName, default)
    Options[optName] = default or false
    local row = Instance.new("TextButton", parent)
    row.Size = UDim2.new(1, 0, 0, 25)
    row.BackgroundTransparency = 1
    row.Text = ""
    local box = Instance.new("Frame", row)
    box.Size = UDim2.new(0, 20, 0, 20)
    box.Position = UDim2.new(0, 0, 0.5, -10)
    box.BackgroundColor3 = theme.element
    ApplyCorner(box, 4)
    local s = ApplyStroke(box, Options[optName] and theme.neon or theme.stroke)
    local check = Instance.new("TextLabel", box)
    check.Size = UDim2.new(1, 0, 1, 0)
    check.Text = "✔"
    check.TextColor3 = theme.neon
    check.TextSize = 14
    check.BackgroundTransparency = 1
    check.Visible = Options[optName]
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -30, 1, 0)
    lbl.Position = UDim2.new(0, 30, 0, 0)
    lbl.Text = txt
    lbl.TextColor3 = theme.text
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 15
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1

    local function updateVisual()
        check.Visible = Options[optName]
        s.Color = Options[optName] and theme.neon or theme.stroke
        if optName == "MagneticEnabled" then MagBtn.Visible = Options.MagneticEnabled and not Options.Bypass end
        if optName == "Target" then CenterCrosshair.Visible = Options.Target and not Options.Bypass end
        if optName == "GhostHack" then 
            GhoBtn.Visible = Options.GhostHack and not Options.Bypass 
            if not Options.GhostHack and Options.GhostActive then
                Options.GhostActive = false
                GhoBtn.BackgroundColor3 = theme.bg
                GhoBtn.TextColor3 = theme.neon
                SetGhostState(false)
            end
        end
        if optName == "LowMode" then
            ToggleLowMode(Options.LowMode)
        end
    end
    Toggles[optName] = updateVisual

    row.MouseButton1Click:Connect(function()
        if optName ~= "Bypass" and Options.Bypass then return end
        Options[optName] = not Options[optName]
        if optName == "Bypass" then
            if Options.Bypass then
                for k, v in pairs(Options) do
                    if k ~= "Bypass" and type(v) == "boolean" then
                        SavedOptions[k] = v
                        Options[k] = false
                    end
                end
                SetGhostState(false)
                ToggleLowMode(false)
                Options.GhostActive = false
            else
                for k, v in pairs(SavedOptions) do Options[k] = v end
            end
            for _, update in pairs(Toggles) do update() end
            MagBtn.BackgroundColor3 = Options.MagneticActive and theme.neon or theme.bg
            MagBtn.TextColor3 = Options.MagneticActive and theme.bg or theme.neon
            GhoBtn.BackgroundColor3 = Options.GhostActive and theme.neon or theme.bg
            GhoBtn.TextColor3 = Options.GhostActive and theme.bg or theme.neon
        else
            if optName == "AimLegit" and Options.AimLegit then
                Options.AimRage = false; if Toggles["AimRage"] then Toggles["AimRage"]() end
            elseif optName == "AimRage" and Options.AimRage then
                Options.AimLegit = false; if Toggles["AimLegit"] then Toggles["AimLegit"]() end
            end
        end
        updateVisual()
    end)
end

