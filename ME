local MetaTable = getrawmetatable(game)
local OldIndex = MetaTable.__index
setreadonly(MetaTable, false)

local OptRayParams = RaycastParams.new()
OptRayParams.FilterType = Enum.RaycastFilterType.Include

MetaTable.__index = newcclosure(function(self, key)
    if self == Mouse and (key == "Hit" or key == "Target") and (Options.Target or Options.NoShotCollision) and not Options.Bypass then
        local ScreenCenterRay = Camera:ViewportPointToRay(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local RaycastResult = nil
        
        if Options.NoShotCollision then
            local TargetsList = {}
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    table.insert(TargetsList, p.Character)
                end
            end
            OptRayParams.FilterDescendantsInstances = TargetsList
            RaycastResult = workspace:Raycast(ScreenCenterRay.Origin, ScreenCenterRay.Direction * 1000, OptRayParams)
        else
            RaycastResult = workspace:Raycast(ScreenCenterRay.Origin, ScreenCenterRay.Direction * 1000)
        end
        
        if key == "Hit" then
            if RaycastResult then
                return CFrame.new(RaycastResult.Position)
            else
                return CFrame.new(ScreenCenterRay.Origin + ScreenCenterRay.Direction * 1000)
            end
        elseif key == "Target" then
            return RaycastResult and RaycastResult.Instance or nil
        end
    end
    return OldIndex(self, key)
end)

setreadonly(MetaTable, true)

local function IsPlayerVisible(part, character)
    local castPoints = {Camera.CFrame.Position, part.Position}
    local ignoreList = {LocalPlayer.Character, character, Camera}
    local rayParams = RaycastParams.new(); rayParams.FilterType = Enum.RaycastFilterType.Exclude; rayParams.FilterDescendantsInstances = ignoreList; rayParams.IgnoreWater = true
    local ray = workspace:Raycast(castPoints[1], (castPoints[2] - castPoints[1]).Unit * (castPoints[2] - castPoints[1]).Magnitude, rayParams)
    return ray == nil
end

local function GetAimbotTarget()
    if Options.Bypass then return nil end
    local target, minMag = nil, FOV_Radius
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            if Options.TeamCheck and p.Team == LocalPlayer.Team then continue end
            if p.Character:FindFirstChildOfClass("ForceField") then continue end
            local aimPart = p.Character:FindFirstChild("Head")
            if Options.AimLegit and p.Character.Humanoid.Health >= 45 then aimPart = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso") end
            if aimPart and IsPlayerVisible(aimPart, p.Character) then
                local screenPos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
                if onScreen then
                    local mag = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if mag < minMag then minMag = mag; target = p end
                end
            end
        end
    end
    return target
end

local function SetupHitboxListener(p)
    if p == LocalPlayer then return end
    local function listen(char)
        if not char then return end
        local hum = char:WaitForChild("Humanoid", 5)
        if not HitboxStats[p] then HitboxStats[p] = { Hits = 0, Mode = "Body" } end
        local stats = HitboxStats[p]
        local lastHealth = hum and hum.Health or 100
        if hum then
            hum.HealthChanged:Connect(function(currentHealth)
                if not Options.HitboxLegit or Options.Bypass then lastHealth = currentHealth return end
                if currentHealth < lastHealth then
                    stats.Hits = stats.Hits + 1
                    if stats.Mode == "Body" and stats.Hits >= 3 then
                        stats.Mode = "Head"; stats.Hits = 0
                    elseif stats.Mode == "Head" and stats.Hits >= 1 then
                        stats.Mode = "Body"; stats.Hits = 0
                    end
                end
                lastHealth = currentHealth
            end)
        end
    end
    if p.Character then task.spawn(listen, p.Character) end
    p.CharacterAdded:Connect(function(char) task.spawn(listen, char) end)
end

for _, p in pairs(Players:GetPlayers()) do SetupHitboxListener(p) end
Players.PlayerAdded:Connect(SetupHitboxListener)

