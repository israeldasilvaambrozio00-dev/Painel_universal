local function ProcessObjectLowMode(obj, enabled)
    if enabled then
        if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) and not obj:FindFirstChildOfClass("Humanoid") then
            if not OriginalMapMaterials[obj] then
                OriginalMapMaterials[obj] = {Material = obj.Material}
            end
            obj.Material = Enum.Material.SmoothPlastic
        elseif obj:IsA("Texture") or obj:IsA("Decal") then
            if not OriginalMapMaterials[obj] then
                OriginalMapMaterials[obj] = {Transparency = obj.Transparency}
            end
            obj.Transparency = 1
        end
    else
        local data = OriginalMapMaterials[obj]
        if data then
            if obj:IsA("BasePart") then
                obj.Material = data.Material
            elseif obj:IsA("Texture") or obj:IsA("Decal") then
                obj.Transparency = data.Transparency
            end
        end
    end
end

local function ToggleLowMode(enabled)
    if enabled then
        for _, obj in pairs(workspace:GetDescendants()) do
            ProcessObjectLowMode(obj, true)
        end
    else
        for obj, _ in pairs(OriginalMapMaterials) do
            if obj.Parent then
                ProcessObjectLowMode(obj, false)
            end
        end
        OriginalMapMaterials = {}
    end
end

workspace.DescendantAdded:Connect(function(descendant)
    if Options.LowMode and not Options.Bypass then
        task.wait()
        if descendant.Parent then
            ProcessObjectLowMode(descendant, true)
        end
    end
end)

local function ToggleWallTransparency(enabled)
    if enabled then
        OriginalWallTransparencies = {}
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) and not obj:FindFirstChildOfClass("Humanoid") then
                if not obj.Name:lower():find("baseplate") then
                    OriginalWallTransparencies[obj] = obj.Transparency
                    obj.Transparency = 0.60 
                end
            end
        end
    else
        for obj, transparency in pairs(OriginalWallTransparencies) do
            if obj.Parent and obj:IsA("BasePart") then
                obj.Transparency = transparency
            end
        end
        OriginalWallTransparencies = {}
    end
end

local function SetGhostState(enabled)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if enabled then
        if hrp and char:FindFirstChildOfClass("Humanoid") then
            char.Archivable = true
            GhostAnchorPos = hrp.CFrame
            
            GhostClone = char:Clone()
            GhostClone.Name = "Ghost_Visual"
            
            for _, child in pairs(GhostClone:GetDescendants()) do
                if child:IsA("BasePart") then
                    child.Transparency = 0.7 
                    child.CanCollide = false
                end
            end
            
            GhostClone.Parent = workspace
            char.Archivable = false
            ToggleWallTransparency(true)
        end
    else
        ToggleWallTransparency(false)
        if GhostClone and GhostClone:FindFirstChild("HumanoidRootPart") and hrp then
            hrp.CFrame = GhostClone.HumanoidRootPart.CFrame
        end
        if GhostClone then
            GhostClone:Destroy()
            GhostClone = nil
        end
        GhostAnchorPos = nil
        
        if char and char:FindFirstChildOfClass("Humanoid") then
            Camera.CameraSubject = char:FindFirstChildOfClass("Humanoid")
        end
    end
end

